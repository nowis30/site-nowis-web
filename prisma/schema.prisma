generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ASSISTANT
  PORTAL_USER
}

enum ContactType {
  PROSPECT
  CLIENT
  PARTENAIRE
  ORGANIZATION
  PARTICIPANT
}

enum OrganizationType {
  SCHOOL
  COMMUNITY_ORG
  DAYCARE
  CAMP
  OTHER
}

enum OrganizationStatus {
  ACTIVE
  LEAD
  INACTIVE
}

enum InquiryStatus {
  NEW
  QUALIFIED
  CLOSED
}

enum CaseType {
  CLIENT
  SUPPORT
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  CLOSED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskType {
  CALL
  EMAIL
  SONG
  FOLLOW_UP
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
}

enum MessageSenderType {
  ADMIN
  CLIENT
}

enum AppointmentType {
  VISIT
  CALL
  FOLLOWUP
  MEETING
  INSPECTION
  DEADLINE
  REMINDER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  DONE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum ActivityType {
  NOTE
  CALL
  MESSAGE
  EMAIL
  APPOINTMENT
  INVOICE
  PAYMENT
  FORM
  FORM_SUBMISSION
  FILE
  TASK
}

enum WorkshopAudienceType {
  PRESCHOOL
  ELEMENTARY
  TEENS
  MIXED
}

enum WorkshopFormat {
  IN_PERSON
  VIRTUAL
  HYBRID
}

enum WorkshopRequestType {
  ORGANIZATION
  CLIENT
}

enum WorkshopDeliveryFormat {
  SUR_PLACE
  EN_LIGNE
  A_DETERMINER
}

enum WorkshopTargetAudience {
  PERSONNES_AGEES
  JEUNES
  ADULTES
  FAMILLE
  ORGANISME
  AUTRE
}

enum WorkshopDurationPreset {
  M60
  M90
  M120
  PERSONNALISE
}

enum WorkshopPricingMode {
  HORAIRE
  PAR_PERSONNE
  PERSONNALISE
}

enum WorkshopRequestStatus {
  BROUILLON
  EN_ATTENTE_RDV
  RDV_PLANIFIE
  CONFIRME
  TERMINE
  ANNULE
  NEW
  CONTACTED
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum WorkshopAppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  DONE
}

enum SongRequestStatus {
  NEW
  CONTACTED
  QUOTED
  IN_PROGRESS
  IN_PRODUCTION
  DELIVERED
  COMPLETED
  CANCELLED
}

enum LinkedType {
  CONTACT
  ORGANIZATION
  INQUIRY
  CASE
  APPOINTMENT
  INVOICE
  ACTIVITY
  SONG_REQUEST
  WORKSHOP_REQUEST
  WORKSHOP_APPOINTMENT
}

enum FileVisibility {
  ADMIN_ONLY
  CLIENT_VISIBLE
}

model User {
  id           String          @id @default(uuid()) @db.Uuid
  email        String          @unique
  fullName     String
  passwordHash String
  role         UserRole        @default(ASSISTANT)
  isActive     Boolean         @default(true)
  contactId     String?         @unique @db.Uuid
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  createdCases               CaseRecord[]         @relation("CaseCreatedBy")
  assignedTasks              Task[]               @relation("TaskAssignedTo")
  createdTasks               Task[]               @relation("TaskCreatedBy")
  authoredNotes              CaseNote[]
  uploadedDocuments          Document[]           @relation("DocumentUploadedBy")
  uploadedFileDocuments      FileDocument[]       @relation("FileDocumentUploadedBy")
  communications             Communication[]       @relation("CommunicationUser")
  handledCommunications      Communication[]       @relation("CommunicationHandledBy")
  appointments               Appointment[]
  activities                 Activity[]
  outboundEmails             OutboundEmail[]
  contact                    Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  oauthAccounts              ClientOAuthAccount[]

  @@map("users")
}

model ClientOAuthAccount {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  provider          String
  providerAccountId String
  email             String?
  name              String?
  image             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([email])
  @@map("client_oauth_accounts")
}

model Contact {
  id              String          @id @default(uuid()) @db.Uuid
  type            ContactType
  fullName        String
  companyName     String?
  email           String?
  phone           String?
  preferredLocale String?         @default("fr-CA")
  source          String?
  tags            String[]
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  inquiries       Inquiry[]
  cases           CaseRecord[]
  communications  Communication[]
  messages        Message[]
  appointments    Appointment[]
  invoices        Invoice[]
  activities      Activity[]
  fileDocuments   FileDocument[]
  songRequests    SongRequest[]
  organizationLinks OrganizationContact[]
  workshopRequests WorkshopRequest[]
  workshopClientRequests WorkshopRequest[] @relation("WorkshopRequestClient")
  workshopAppointments WorkshopAppointment[]
  outboundEmails  OutboundEmail[]
  userAccount     User?

  @@index([type])
  @@index([fullName])
  @@map("contacts")
}

model Organization {
  id                  String                 @id @default(uuid()) @db.Uuid
  name                String
  type                OrganizationType      @default(OTHER)
  email               String?
  phone               String?
  address             String?
  city                String?
  notes               String?
  status              OrganizationStatus    @default(LEAD)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  contacts            OrganizationContact[]
  workshopRequests    WorkshopRequest[]
  workshopAppointments WorkshopAppointment[]

  @@index([name])
  @@index([status])
  @@map("organizations")
}

model OrganizationContact {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  contactId      String?       @db.Uuid
  fullName       String
  role           String?
  email          String?
  phone          String?
  isPrimary      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact        Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  workshopRequests WorkshopRequest[]
  workshopAppointments WorkshopAppointment[]

  @@index([organizationId])
  @@index([contactId])
  @@map("organization_contacts")
}

model WorkshopRequest {
  id                    String                 @id @default(uuid()) @db.Uuid
  organizationId        String?                @db.Uuid
  contactId             String?                @db.Uuid
  clientId              String?                @db.Uuid
  organizationContactId String?                @db.Uuid
  title                 String
  workshopType          WorkshopRequestType    @default(ORGANIZATION)
  organizationName      String?
  contactPerson         String?
  contactPhone          String?
  contactEmail          String?
  addressOrLocation     String?
  deliveryFormat        WorkshopDeliveryFormat @default(A_DETERMINER)
  participantEstimate   Int?
  targetAudience        WorkshopTargetAudience @default(AUTRE)
  durationPreset        WorkshopDurationPreset @default(M90)
  durationCustomMinutes Int?
  pricingMode           WorkshopPricingMode    @default(HORAIRE)
  basePrice             Decimal?               @db.Decimal(10, 2)
  discountPercent       Decimal?               @db.Decimal(5, 2)
  finalPrice            Decimal?               @db.Decimal(10, 2)
  internalNotes         String?
  clientNotes           String?
  calendlyEventUri      String?
  calendlyInviteeUri    String?
  calendlyUrl           String?
  scheduledAt           DateTime?
  clientAccessToken     String?                @unique
  audienceType          WorkshopAudienceType   @default(MIXED)
  ageRange              String?
  estimatedParticipants Int?
  requestedDate         DateTime?
  requestedTime         String?
  preferredDays         String[]
  format                WorkshopFormat         @default(IN_PERSON)
  location              String?
  workshopTheme         String
  objectives            String
  notes                 String?
  status                WorkshopRequestStatus  @default(NEW)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  organization          Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  contact               Contact?               @relation(fields: [contactId], references: [id], onDelete: SetNull)
  client                Contact?               @relation("WorkshopRequestClient", fields: [clientId], references: [id], onDelete: SetNull)
  organizationContact   OrganizationContact?   @relation(fields: [organizationContactId], references: [id], onDelete: SetNull)
  appointments          WorkshopAppointment[]

  @@index([organizationId])
  @@index([contactId])
  @@index([clientId])
  @@index([status])
  @@index([clientAccessToken])
  @@map("workshop_requests")
}

model WorkshopAvailability {
  id         String   @id @default(uuid()) @db.Uuid
  weekday    Int
  startTime  String
  endTime    String
  isActive   Boolean  @default(true)
  capacity   Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([weekday, isActive])
  @@map("workshop_availabilities")
}

model WorkshopAppointment {
  id                    String                     @id @default(uuid()) @db.Uuid
  workshopRequestId     String                     @db.Uuid
  organizationId        String                     @db.Uuid
  contactId             String?                    @db.Uuid
  organizationContactId String?                    @db.Uuid
  title                 String
  description           String?
  startAt               DateTime
  endAt                 DateTime
  status                WorkshopAppointmentStatus  @default(PENDING)
  location              String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  workshopRequest       WorkshopRequest            @relation(fields: [workshopRequestId], references: [id], onDelete: Cascade)
  organization          Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact               Contact?                   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  organizationContact   OrganizationContact?       @relation(fields: [organizationContactId], references: [id], onDelete: SetNull)

  @@index([workshopRequestId])
  @@index([organizationId])
  @@index([contactId])
  @@index([startAt])
  @@map("workshop_appointments")
}

model Message {
  id         String            @id @default(uuid()) @db.Uuid
  contactId  String            @db.Uuid
  senderType MessageSenderType
  content    String
  createdAt  DateTime          @default(now())
  isRead     Boolean           @default(false)

  contact    Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, createdAt])
  @@index([contactId, senderType, isRead])
  @@map("messages")
}

model Inquiry {
  id             String       @id @default(uuid()) @db.Uuid
  subject        String
  message        String
  source         String?
  status         InquiryStatus @default(NEW)
  contactId      String?      @db.Uuid
  caseId         String?      @db.Uuid
  receivedAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  caseRecord     CaseRecord?  @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([caseId])
  @@map("inquiries")
}

model CaseRecord {
  id               String       @id @default(uuid()) @db.Uuid
  title            String
  description      String?
  type             CaseType
  status           CaseStatus   @default(OPEN)
  contactId        String?      @db.Uuid
  ownerUserId      String?      @db.Uuid
  referenceCode    String       @unique
  openedAt         DateTime     @default(now())
  closedAt         DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  contact          Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  ownerUser        User?        @relation("CaseCreatedBy", fields: [ownerUserId], references: [id], onDelete: SetNull)
  notes            CaseNote[]
  tasks            Task[]
  inquiries        Inquiry[]

  @@index([type, status])
  @@index([contactId])
  @@map("cases")
}

model CaseNote {
  id           String      @id @default(uuid()) @db.Uuid
  caseId       String      @db.Uuid
  authorUserId String?     @db.Uuid
  content      String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  caseRecord   CaseRecord  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author       User?       @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@map("case_notes")
}

model Task {
  id             String       @id @default(uuid()) @db.Uuid
  title          String
  description    String?
  type           TaskType     @default(FOLLOW_UP)
  payload        Json?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  caseId         String?      @db.Uuid
  assignedToId   String?      @db.Uuid
  createdById    String?      @db.Uuid
  songRequestId  String?      @db.Uuid
  linkedType     LinkedType?
  linkedId       String?      @db.Uuid
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  caseRecord     CaseRecord?  @relation(fields: [caseId], references: [id], onDelete: SetNull)
  assignedTo     User?        @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy      User?        @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  songRequest    SongRequest? @relation(fields: [songRequestId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([songRequestId])
  @@index([linkedType, linkedId])
  @@map("tasks")
}

model Document {
  id             String       @id @default(uuid()) @db.Uuid
  fileName       String
  fileUrl        String
  mimeType       String?
  sizeBytes      Int?
  linkedType     LinkedType
  linkedId       String       @db.Uuid
  uploadedById   String?      @db.Uuid
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  uploadedBy     User?        @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([linkedType, linkedId])
  @@map("documents")
}

model FileDocument {
  id               String         @id @default(uuid()) @db.Uuid
  contactId        String?        @db.Uuid
  songRequestId    String?        @db.Uuid
  uploadedByUserId String?        @db.Uuid
  filename         String
  originalName     String
  mimeType         String
  size             Int
  storageKey       String         @unique
  url              String
  category         String
  visibility       FileVisibility @default(CLIENT_VISIBLE)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  contact          Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  songRequest      SongRequest?   @relation(fields: [songRequestId], references: [id], onDelete: SetNull)
  uploadedByUser   User?          @relation("FileDocumentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([songRequestId])
  @@index([visibility])
  @@index([createdAt])
  @@map("file_documents")
}

model Communication {
  id             String                 @id @default(uuid()) @db.Uuid
  contactId      String?                @db.Uuid
  userId         String?                @db.Uuid
  handledById    String?                @db.Uuid
  channel        String
  subject        String?
  body           String
  direction      CommunicationDirection
  linkedType     LinkedType
  linkedId       String                 @db.Uuid
  sentAt         DateTime               @default(now())
  handledAt      DateTime?
  createdAt      DateTime               @default(now())

  contact        Contact?               @relation(fields: [contactId], references: [id], onDelete: SetNull)
  user           User?                  @relation("CommunicationUser", fields: [userId], references: [id], onDelete: SetNull)
  handledBy      User?                  @relation("CommunicationHandledBy", fields: [handledById], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([handledAt])
  @@index([handledById])
  @@index([linkedType, linkedId])
  @@map("communications")
}

model Appointment {
  id          String            @id @default(uuid()) @db.Uuid
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  type        AppointmentType   @default(MEETING)
  status      AppointmentStatus @default(PENDING)
  contactId   String?           @db.Uuid
  userId      String?           @db.Uuid
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  contact     Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([startAt])
  @@map("appointments")
}

model Invoice {
  id          String        @id @default(uuid()) @db.Uuid
  number      String        @unique
  contactId   String        @db.Uuid
  issueDate   DateTime      @default(now())
  dueDate     DateTime
  amount      Decimal       @db.Decimal(10, 2)
  status      InvoiceStatus @default(DRAFT)
  description String?
  fileUrl     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  contact     Contact       @relation(fields: [contactId], references: [id], onDelete: Restrict)

  @@index([contactId])
  @@index([status])
  @@map("invoices")
}

model Activity {
  id            String       @id @default(uuid()) @db.Uuid
  type          ActivityType @default(NOTE)
  title         String
  description   String?
  contactId     String?      @db.Uuid
  appointmentId String?      @db.Uuid
  invoiceId     String?      @db.Uuid
  songRequestId String?      @db.Uuid
  userId        String?      @db.Uuid
  createdAt     DateTime     @default(now())

  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  songRequest   SongRequest? @relation(fields: [songRequestId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([songRequestId])
  @@index([createdAt])
  @@map("activities")
}

model OutboundEmail {
  id                String    @id @default(uuid()) @db.Uuid
  trackingToken     String    @unique
  contactId         String    @db.Uuid
  createdById       String?   @db.Uuid
  recipientEmail    String
  subject           String
  messagePreview    String
  provider          String?
  providerMessageId String?
  sendError         String?
  sentAt            DateTime  @default(now())
  openedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  contact           Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy         User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([openedAt])
  @@index([sentAt])
  @@map("outbound_emails")
}

model SongRequest {
  id                   String            @id @default(uuid()) @db.Uuid
  contactId            String            @db.Uuid
  title                String?
  fullName             String
  email                String
  phone                String
  songType             String
  language             String?
  occasion             String
  eventType            String?
  recipientName        String
  specialMessage       String?
  style                String
  mood                 String
  tempo                String?
  theme                String?
  description          String?
  inspirations         String?
  lyrics               String?
  structureVerse       String?
  structureChorus      String?
  structureBridge      String?
  fileUrl              String?
  details              String
  budget               Decimal?          @db.Decimal(10, 2)
  desiredDeadline      DateTime?
  source               String            @default("website")
  status               SongRequestStatus @default(NEW)
  convertedAppointmentId String?         @db.Uuid
  convertedInvoiceId   String?           @db.Uuid
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  contact              Contact           @relation(fields: [contactId], references: [id], onDelete: Restrict)
  activities           Activity[]
  fileDocuments        FileDocument[]
  tasks                Task[]

  @@index([contactId])
  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("song_requests")
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String?
  rating    Int      // 1 à 5
  comment   String
  context   String?  // ex: "Chanson personnalisée", "Atelier créatif"
  status    String   @default("pending") // pending, approved, rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("reviews")
}
