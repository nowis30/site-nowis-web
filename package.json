{
  "name": "nowis-app",
  "version": "1.0.0",
  "description": "NOWIS - Création de contenu IA (T-shirts, Musique Suno, Vidéos Revide.ai)",
  "scripts": {
    "dev": "next dev",
    "dev:local": "next dev -p 3000",
    "prebuild": "node scripts/prisma-safe-prebuild.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test:contract": "tsx scripts/admin-runtime-contract.test.ts",
    "test:song-request-api-security": "tsx scripts/song-request-api-security-check.ts",
    "test:workshop-request-validation": "tsx scripts/workshop-request-validation-check.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:init": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/migrations/20260323_init/migration.sql",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:archive:housing": "tsx scripts/archive-housing-domain.ts",
    "db:deprecate:housing:safe": "npm run db:archive:housing && npm run prisma:migrate:deploy && npm run prisma:generate",
    "tasks:backfill-types": "tsx scripts/backfill-task-types.ts",
    "contacts:backfill-profile-meta": "tsx scripts/backfill-contact-profile-meta.ts",
    "quality:quick": "npm run type-check && npm run build",
    "crm:release:tasks": "npm run prisma:migrate:deploy && npm run prisma:generate && npm run tasks:backfill-types && npm run quality:quick",
    "crm:reset-password": "tsx scripts/reset-crm-password.ts",
    "sync:youtube": "node scripts/sync-youtube.js",
    "sync:spotify": "node scripts/sync-spotify.js",
    "sync:songs": "node scripts/sync-songs.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.883.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.16.2",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "formidable": "^3.5.4",
    "glob": "^10.5.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.6.0",
    "next": "^14.0.0",
    "nodemailer": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.72.0",
    "react-icons": "^5.6.0",
    "resend": "^6.9.4",
    "rimraf": "^5.0.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.0.0",
    "postcss": "^8.4.31",
    "prisma": "^6.16.2",
    "tailwindcss": "^3.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
